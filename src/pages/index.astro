---
import BaseHead from '../components/base_head.astro';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="index" id="index">
				<h1>Izzy Stein</h1>
				<h3>Computer Science Major for Bachelor of Science at Rensselaer Polytechnic Institute</h3>
			</div>
			<div class="about" id="about">
				<h1>About</h1>
				<p>
					I'm a full stack developer with experience in a variety of languages and frameworks. 
					I'm passionate about open source and have contributed to several projects. 
					I'm also interested in data science, and have expierence with PostgreSQL, Docker, and AWS. 
					I'm currently looking for internships and full-time positions in software development, data science, and related fields.
				</p>
			</div>
			<div class="projects" id="projects">
				<h1>Projects</h1>
				<h3>Personal Projections</h3>
				<p>
					<h5>Website</h5>
					<a href="https://github.com/offline171/offline171.github.io" target="_blank">Github</a>

					<h5>Budget Tracker</h5>
					<a href="https://github.com/offline171/Budget" target="_blank">Github</a>

					<h5>Vacation Library</h5>
					<a href="https://github.com/offline171/Vacations" target="_blank">Github</a>
					
				</p>
				<h3>Open Source Contributions</h3>
				<p>
					<h5>LEGUP</h5>
					<a href="https://github.com/Bram-Hub/LEGUP" target="_blank">Github</a>

					<h5>Shubble</h5>
					<a href="https://shuttles.rpi.edu/" target="_blank">Website</a><br>
					<a href="https://github.com/wtg/shubble" target="_blank">Github</a>

					<h5>EzASM</h5>
					<a href="https://github.com/ezasm-org/ezasm" target="_blank">Github</a>
				</p>
			</div>
			<div class="blog" id="blog">
				<h1>Blog</h1>
				<p>
					This is where I post about my projects, progress, and what I'm doing in my leadership roles.
					<a href="https://www.concealedvacations.com/" target="_blank">Website</a><br>
					<a href="https://github.com/offline171/basicconcealedvacations" target="_blank">Github</a>
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>